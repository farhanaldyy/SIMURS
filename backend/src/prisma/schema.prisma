  diisi       Boolean
  keterangan  String?  @db.VarChar(200)
  created_by  Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([periode_id])
  @@index([unit_id])
  @@map("asesmen_pra_operasi")
}

