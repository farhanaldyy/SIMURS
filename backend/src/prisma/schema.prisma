generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  nama            String   @db.VarChar(100)
  username        String   @unique @db.VarChar(50)
  password_hash   String   @db.VarChar(255)
  role            UserRole @default(petugas)
  unit_id         Int?
  aktif           Boolean  @default(true)
  allowed_modules String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  unit                    Unit?                    @relation(fields: [unit_id], references: [id])
  giziWaktuMakanans       GiziWaktuMakanan[]
  giziSisaMakanans        GiziSisaMakanan[]
  giziKesalahanDiets      GiziKesalahanDiet[]
  giziIdentifikasiPasiens GiziIdentifikasiPasien[]
  kepatuhanKebersihanTangans KepatuhanKebersihanTangan[]
  kepatuhanApds           KepatuhanApd[]
  rehabPasienDropOuts     RehabPasienDropOut[]
  rehabKesalahanTindakans RehabKesalahanTindakan[]
  rehabWaktuTunggus       RehabWaktuTunggu[]
  rehabKepatuhanIdentitass RehabKepatuhanIdentitas[]
  rehabKepuasanPasiens    RehabKepuasanPasien[]
  laundryKetepatanLinens  LaundryKetepatanLinen[]
  laundryLinenHilangs     LaundryLinenHilang[]
  radiologiJadwalDokters      RadiologiJadwalDokter[]
  radiologiThoraxSesuaiJadwals RadiologiThoraxSesuaiJadwal[]
  radiologiThoraxLuarJadwals   RadiologiThoraxLuarJadwal[]
  radiologiFotoUlangs         RadiologiFotoUlang[]
  radiologiInfoTindakans      RadiologiInfoTindakan[]
  radiologiIdentifikasiPasiens RadiologiIdentifikasiPasien[]
  laboratoriumJadwalDokters      LaboratoriumJadwalDokter[]
  laboratoriumWaktuTungguLt140s  LaboratoriumWaktuTungguLt140[]
  laboratoriumWaktuTungguGt140s  LaboratoriumWaktuTungguGt140[]
  laboratoriumHasilKritis        LaboratoriumHasilKritis[]
  laboratoriumKesalahanInputs    LaboratoriumKesalahanInput[]
  laboratoriumKerusakanSampels   LaboratoriumKerusakanSampel[]
  laboratoriumKepatuhanIdentifikasis LaboratoriumKepatuhanIdentifikasi[]
  laboratoriumEkspertisiDokters  LaboratoriumEkspertisiDokter[]

  @@map("users")
}

model Unit {
  id         Int      @id @default(autoincrement())
  nama_unit  String   @db.VarChar(100)
  kode_unit  String   @unique @db.VarChar(20)
  aktif      Boolean  @default(true)
  created_at DateTime @default(now())

  users                   User[]
  giziWaktuMakanans       GiziWaktuMakanan[]
  giziSisaMakanans        GiziSisaMakanan[]
  giziKesalahanDiets      GiziKesalahanDiet[]
  giziIdentifikasiPasiens GiziIdentifikasiPasien[]
  kepatuhanKebersihanTangans KepatuhanKebersihanTangan[]
  kepatuhanApds           KepatuhanApd[]
  rehabPasienDropOuts     RehabPasienDropOut[]
  rehabKesalahanTindakans RehabKesalahanTindakan[]
  rehabWaktuTunggus       RehabWaktuTunggu[]
  rehabKepatuhanIdentitass RehabKepatuhanIdentitas[]
  rehabKepuasanPasiens    RehabKepuasanPasien[]
  laundryKetepatanLinens  LaundryKetepatanLinen[]
  laundryLinenHilangs     LaundryLinenHilang[]
  radiologiJadwalDokters      RadiologiJadwalDokter[]
  radiologiThoraxSesuaiJadwals RadiologiThoraxSesuaiJadwal[]
  radiologiThoraxLuarJadwals   RadiologiThoraxLuarJadwal[]
  radiologiFotoUlangs         RadiologiFotoUlang[]
  radiologiInfoTindakans      RadiologiInfoTindakan[]
  radiologiIdentifikasiPasiens RadiologiIdentifikasiPasien[]
  laboratoriumJadwalDokters      LaboratoriumJadwalDokter[]
  laboratoriumWaktuTungguLt140s  LaboratoriumWaktuTungguLt140[]
  laboratoriumWaktuTungguGt140s  LaboratoriumWaktuTungguGt140[]
  laboratoriumHasilKritis        LaboratoriumHasilKritis[]
  laboratoriumKesalahanInputs    LaboratoriumKesalahanInput[]
  laboratoriumKerusakanSampels   LaboratoriumKerusakanSampel[]
  laboratoriumKepatuhanIdentifikasis LaboratoriumKepatuhanIdentifikasi[]
  laboratoriumEkspertisiDokters  LaboratoriumEkspertisiDokter[]

  @@map("units")
}

model Periode {
  id                      Int                      @id @default(autoincrement())
  bulan                   Int                      @db.TinyInt
  tahun                   Int                      @db.SmallInt
  status                  PeriodeStatus            @default(open)
  created_at              DateTime                 @default(now())
  giziWaktuMakanans       GiziWaktuMakanan[]
  giziSisaMakanans        GiziSisaMakanan[]
  giziKesalahanDiets      GiziKesalahanDiet[]
  giziIdentifikasiPasiens GiziIdentifikasiPasien[]
  kepatuhanKebersihanTangans KepatuhanKebersihanTangan[]
  kepatuhanApds           KepatuhanApd[]
  rehabPasienDropOuts     RehabPasienDropOut[]
  rehabKesalahanTindakans RehabKesalahanTindakan[]
  rehabWaktuTunggus       RehabWaktuTunggu[]
  rehabKepatuhanIdentitass RehabKepatuhanIdentitas[]
  rehabKepuasanPasiens    RehabKepuasanPasien[]
  laundryKetepatanLinens  LaundryKetepatanLinen[]
  laundryLinenHilangs     LaundryLinenHilang[]
  radiologiJadwalDokters      RadiologiJadwalDokter[]
  radiologiThoraxSesuaiJadwals RadiologiThoraxSesuaiJadwal[]
  radiologiThoraxLuarJadwals   RadiologiThoraxLuarJadwal[]
  radiologiFotoUlangs         RadiologiFotoUlang[]
  radiologiInfoTindakans      RadiologiInfoTindakan[]
  radiologiIdentifikasiPasiens RadiologiIdentifikasiPasien[]
  laboratoriumJadwalDokters      LaboratoriumJadwalDokter[]
  laboratoriumWaktuTungguLt140s  LaboratoriumWaktuTungguLt140[]
  laboratoriumWaktuTungguGt140s  LaboratoriumWaktuTungguGt140[]
  laboratoriumHasilKritis        LaboratoriumHasilKritis[]
  laboratoriumKesalahanInputs    LaboratoriumKesalahanInput[]
  laboratoriumKerusakanSampels   LaboratoriumKerusakanSampel[]
  laboratoriumKepatuhanIdentifikasis LaboratoriumKepatuhanIdentifikasi[]
  laboratoriumEkspertisiDokters  LaboratoriumEkspertisiDokter[]

  @@unique([bulan, tahun])
  @@map("periode")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  user_id    Int
  tabel      String    @db.VarChar(50)
  record_id  Int
  aksi       AuditAksi
  data_lama  Json?
  data_baru  Json?
  created_at DateTime  @default(now())

  @@index([tabel])
  @@index([user_id])
  @@map("audit_log")
}

