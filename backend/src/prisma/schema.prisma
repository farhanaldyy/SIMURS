  periode_id  Int
  unit_id     Int
  jenis       JenisSurgical
  tanggal     DateTime @db.Date
  nama_pasien String   @db.VarChar(100)
  no_rm       String   @db.VarChar(20)
  dpjp        String   @db.VarChar(100)
  sign_in     Boolean
