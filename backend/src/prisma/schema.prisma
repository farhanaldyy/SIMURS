  keterangan      String?  @db.VarChar(200)
  created_by      Int
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([periode_id])
  @@map("penandaan_lokasi_operasi")
}

// === ENUMS ===

enum UserRole {
  admin
  pic_mutu
  komite
  petugas
}

enum PeriodeStatus {
  open
  closed
}

enum AuditAksi {
  create
  update
  delete
}

enum DilakukanEnum {
  dilakukan
  tidak_dilakukan @map("tidak dilakukan")
}

enum IdentifikasiEnum {
  dilakukan
  tidak_dilakukan   @map("tidak dilakukan")
  tidak_ada_peluang @map("tidak ada peluang")
}

enum SesuaiEnum {
  sesuai
  tidak_sesuai @map("tidak sesuai")
}

enum SesuaiEnum2 {
  Sesuai
  Tidak_Sesuai @map("Tidak Sesuai")
}

enum JenisInsiden {
  KTD
  KNC
  KPC
  Sentinel
  KTC
}

enum LokasiKematian {
  ranap
  igd
}

enum KategoriVisit {
  cepat
  tepat_waktu
  terlambat
  sangat_terlambat
  tidak_visit
}

enum Triase {
  Merah
  Kuning
  Hijau
  Hitam
}

enum AdaEnum {
  ada
  tidak_ada @map("tidak ada")
}

enum JenisConsent {
  pembedahan
  anestesi
}

enum JenisAsesmen {
  pra_bedah
  pra_anestesi
}

enum JenisSurgical {
  sc
  operasi_umum
}
