generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  nama          String    @db.VarChar(100)
  username      String    @unique @db.VarChar(50)
  password_hash String    @db.VarChar(255)
  role          UserRole  @default(petugas)
  unit_id       Int?
  aktif           Boolean   @default(true)
  allowed_modules String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  unit            Unit?     @relation(fields: [unit_id], references: [id])

  @@map("users")
}

model Unit {
  id         Int      @id @default(autoincrement())
  nama_unit  String   @db.VarChar(100)
  kode_unit  String   @unique @db.VarChar(20)
  aktif      Boolean  @default(true)
  created_at DateTime @default(now())

  users      User[]

  @@map("units")
}

model Periode {
  id         Int           @id @default(autoincrement())
  bulan      Int           @db.TinyInt
  tahun      Int           @db.SmallInt
  status     PeriodeStatus @default(open)
  created_at DateTime      @default(now())

  @@unique([bulan, tahun])
  @@map("periode")
}

model AuditLog {
  id         Int       @id @default(autoincrement())
  user_id    Int
  tabel      String    @db.VarChar(50)
  record_id  Int
  aksi       AuditAksi
  data_lama  Json?
  data_baru  Json?
  created_at DateTime  @default(now())

  @@index([tabel])
  @@index([user_id])
  @@map("audit_log")
}

// === INDIKATOR TABLES ===

model RisikoJatuh {
  id              Int         @id @default(autoincrement())
  periode_id      Int
  unit_id         Int
  nama_pasien     String      @db.VarChar(100)
  usia            Int         @db.TinyInt
  no_rm           String      @db.VarChar(20)
  asesmen_awal    DilakukanEnum
  asesmen_ulang   DilakukanEnum
  intervensi      DilakukanEnum
  edukasi         DilakukanEnum
  created_by      Int
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@index([periode_id])
  @@index([unit_id])
  @@map("risiko_jatuh")
}

model InsidenKeselamatan {
