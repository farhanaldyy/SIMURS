}

model PenandaanLokasiOperasi {
  id              Int      @id @default(autoincrement())
  periode_id      Int
  tanggal         DateTime @db.Date
  nama_pasien     String   @db.VarChar(100)
  no_rm           String   @db.VarChar(20)
  diagnosis       String   @db.VarChar(255)
  dpjp            String   @db.VarChar(100)
  dilakukan       Boolean
